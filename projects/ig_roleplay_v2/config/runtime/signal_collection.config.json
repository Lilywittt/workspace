        "pm10",
        "pm2_5",
        "us_aqi",
        "uv_index"
      ]
    },
    {
      "id": "city_brief_gdelt",
      "kind": "gdelt_news",
      "enabled": true,
      "sourceLabel": "GDELT Tokyo Headlines",
      "query": "Tokyo",
      "maxRecords": 8,
      "timespan": "3d",
      "sort": "datedesc",
      "titleAnyKeywords": [
        "tokyo",
        "akihabara",
        "shibuya",
        "ikebukuro",
        "anime",
        "manga",
        "event",
        "exhibition"
      ],
      "preferSourceCountries": [
        "Japan"
      ],
      "trendKeywords": 4,
      "priorityWeight": 1
