      "limit": 4,
      "freshnessWindowDays": 400,
      "hrefIncludes": [
        "/en/event/"
      ],
      "priorityWeight": 1
    },
    {
      "id": "tokyo_anime_station_feed",
      "kind": "html_link_list",
      "enabled": true,
      "sourceLabel": "Anime Tokyo Station Events",
      "category": "animeFandom",
