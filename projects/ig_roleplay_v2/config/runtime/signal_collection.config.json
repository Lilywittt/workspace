      "id": "weather_open_meteo",
      "kind": "open_meteo_weather",
      "enabled": true,
      "sourceLabel": "Open-Meteo Current Weather",
      "current": [
        "temperature_2m",
        "relative_humidity_2m",
        "apparent_temperature",
        "precipitation",
        "weather_code",
        "wind_speed_10m",
        "cloud_cover"
      ],
